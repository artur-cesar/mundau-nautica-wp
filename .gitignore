# Ambiente
.env
.env.local
.env.*.local

# WordPress core — ignorar tudo
/wp-admin/
/wp-includes/
/wp-*.php
/index.php
/xmlrpc.php
/readme.html
/license.txt
/wp-config.php
/wp-config-sample.php

# wp-content — ignorar tudo por padrão, reincluir seletivamente
/wp-content/*

# index.php de segurança
!/wp-content/index.php

# Tema do projeto
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/mundau-nautica/

# Plugin do projeto
!/wp-content/plugins/
/wp-content/plugins/*
!/wp-content/plugins/mundau-nautica-core/

# Uploads e cache (runtime)
/wp-content/uploads/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/wp-cache-config.php
/wp-content/object-cache.php

# Cache e arquivos gerados
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup-db/
/wp-content/advanced-cache.php
/wp-content/wp-cache-config.php
/wp-content/object-cache.php

# Build
/dist/

# Dependências e ferramentas locais
/node_modules/
/vendor/
*.log
.DS_Store
Thumbs.db
